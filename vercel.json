{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/alerts/run",
      "schedule": "7 13 * * *"
    },
    {
      "path": "/api/maintenance/refresh-scores",
      "schedule": "13 2 * * *"
    },
    {
      "path": "/api/maintenance/weekly-digest",
      "schedule": "37 13 * * 1"
    }
  ]
}
